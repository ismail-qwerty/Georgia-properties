{
  "name": "brookfield-properties-api",
  "version": "1.0.0",
  "description": "Brookfield Properties Platform - Backend API with Node.js, Express, TypeScript, and Supabase",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/server.ts",
    "dev:debug": "NODE_ENV=development tsx watch --inspect src/server.ts",
    "build": "tsc --build",
    "build:clean": "rm -rf dist && npm run build",
    "start": "NODE_ENV=production node dist/server.js",
    "start:prod": "npm run build && npm start",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "db:migrate": "echo \"Run migrations in Supabase SQL Editor\"",
    "db:seed": "echo \"Run seed scripts in Supabase SQL Editor\"",
    "logs": "tail -f logs/app.log",
    "clean": "rm -rf dist node_modules",
    "reinstall": "npm run clean && npm install"
  },
  "keywords": [
    "express",
    "typescript",
    "supabase",
    "api",
    "rest-api",
    "jwt",
    "authentication",
    "postgresql",
    "real-estate",
    "property-management"
  ],
  "author": "Brookfield Properties Development Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/brookfield-properties-api"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.22.0",
    "ws": "^8.21.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
