# ================================================================
# Brookfield Properties Platform - Environment Configuration
# ================================================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# Never commit .env file to version control!
# ================================================================

# ----------------------------------------------------------------
# APPLICATION ENVIRONMENT
# ----------------------------------------------------------------
# Environment: development | staging | production
NODE_ENV=development

# Server port for Express application
PORT=3000

# API version prefix (affects route paths: /api/v1/...)
API_VERSION=v1

# Application name (for logging and monitoring)
APP_NAME="Brookfield Properties API"

# ----------------------------------------------------------------
# SUPABASE DATABASE CONFIGURATION
# ----------------------------------------------------------------
# Get these from: https://app.supabase.com/project/_/settings/api

# Supabase Project URL (format: https://xxxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon/Public Key (safe for client-side use)
# Used for: Client-side authentication, public API calls
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# Supabase Service Role Key (KEEP SECRET - server-side only)
# Used for: Admin operations, bypassing RLS policies, server-side queries
# WARNING: This key has full database access - never expose to clients!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# Supabase Database Direct Connection (optional - for advanced use)
# Get from: https://app.supabase.com/project/_/settings/database
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# Database connection pool settings (optional)
DB_POOL_MIN=2
DB_POOL_MAX=10

# ----------------------------------------------------------------
# JWT AUTHENTICATION CONFIGURATION
# ----------------------------------------------------------------
# Secret key for signing JWT tokens (CRITICAL SECURITY)
# Generate with: openssl rand -base64 64
# MUST be different in production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-64-chars-minimum

# JWT token expiration time
# Format: 60, "2 days", "10h", "7d", "1y"
JWT_EXPIRES_IN=7d

# JWT token issuer (optional - for token validation)
JWT_ISSUER=brookfield-properties-api

# JWT token audience (optional - for token validation)
JWT_AUDIENCE=brookfield-properties-users

# Refresh token expiration (optional - for implementing refresh tokens)
JWT_REFRESH_EXPIRES_IN=30d

# ----------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing) CONFIGURATION
# ----------------------------------------------------------------
# Comma-separated list of allowed origins
# Development: Include localhost ports for frontend
# Production: Only include your production domain(s)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Allow credentials (cookies, authorization headers)
CORS_CREDENTIALS=true

# ----------------------------------------------------------------
# SECURITY CONFIGURATION
# ----------------------------------------------------------------
# Bcrypt password hashing rounds (10-12 recommended, higher = more secure but slower)
BCRYPT_ROUNDS=10

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Rate limiting for authentication endpoints (stricter)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# Session secret for express-session (if using sessions)
SESSION_SECRET=your-session-secret-change-in-production

# ----------------------------------------------------------------
# LOGGING CONFIGURATION
# ----------------------------------------------------------------
# Log level: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info

# Log format: json | simple | combined
LOG_FORMAT=json

# Enable request logging
LOG_REQUESTS=true

# Log file paths (optional - for file logging)
LOG_FILE_ERROR=logs/error.log
LOG_FILE_COMBINED=logs/combined.log

# ----------------------------------------------------------------
# PLATFORM BUSINESS RULES
# ----------------------------------------------------------------
# Currency denomination (always VIEWS for this platform)
CURRENCY=VIEWS

# Default membership tier ID for new users
DEFAULT_TIER_ID=1

# Default minimum withdrawal amount (VIEWS)
DEFAULT_MIN_WITHDRAWAL=50.00

# Default maximum withdrawal amount (VIEWS)
DEFAULT_MAX_WITHDRAWAL=500.00

# Daily task generation reset time (UTC)
DAILY_RESET_HOUR=0

# Number of properties to assign per user (fixed at 3 per PRD)
PROPERTIES_PER_ASSIGNMENT=3

# ----------------------------------------------------------------
# EMAIL CONFIGURATION (Optional - for notifications)
# ----------------------------------------------------------------
# Email service provider: smtp | sendgrid | mailgun | ses
EMAIL_PROVIDER=smtp

# SMTP Configuration (if using SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME="Brookfield Properties"
SMTP_FROM_EMAIL=noreply@brookfieldproperties.com

# SendGrid API Key (if using SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key

# ----------------------------------------------------------------
# EXTERNAL API INTEGRATIONS (Optional)
# ----------------------------------------------------------------
# Payment gateway API keys (if implementing external payments)
PAYMENT_GATEWAY_API_KEY=your-payment-gateway-key
PAYMENT_GATEWAY_SECRET=your-payment-gateway-secret

# SMS service (for 2FA or notifications)
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=BROOKFIELD

# ----------------------------------------------------------------
# MONITORING & ANALYTICS (Optional)
# ----------------------------------------------------------------
# Sentry DSN for error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Google Analytics tracking ID
GA_TRACKING_ID=UA-XXXXXXXXX-X

# ----------------------------------------------------------------
# REDIS CONFIGURATION (Optional - for caching/sessions)
# ----------------------------------------------------------------
# Redis connection URL
REDIS_URL=redis://localhost:6379

# Redis password (if required)
REDIS_PASSWORD=your-redis-password

# Redis database index
REDIS_DB=0

# Cache TTL (time to live) in seconds
CACHE_TTL=3600

# ----------------------------------------------------------------
# FILE UPLOAD CONFIGURATION (Optional)
# ----------------------------------------------------------------
# Max file size in bytes (5MB)
MAX_FILE_SIZE=5242880

# Allowed file types
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Upload directory
UPLOAD_DIR=uploads

# ----------------------------------------------------------------
# CRON JOB CONFIGURATION (Optional)
# ----------------------------------------------------------------
# Enable automated daily quota reset
ENABLE_DAILY_RESET=true

# Cron expression for daily reset (default: every day at midnight UTC)
DAILY_RESET_CRON=0 0 * * *

# ----------------------------------------------------------------
# FEATURE FLAGS (Optional)
# ----------------------------------------------------------------
# Enable user registration
ENABLE_REGISTRATION=true

# Enable user login
ENABLE_LOGIN=true

# Enable wallet operations
ENABLE_WALLET_OPERATIONS=true

# Enable admin panel
ENABLE_ADMIN_PANEL=true

# Maintenance mode (disables all non-admin access)
MAINTENANCE_MODE=false

# ----------------------------------------------------------------
# DEVELOPMENT TOOLS (Development only)
# ----------------------------------------------------------------
# Enable GraphQL playground
ENABLE_GRAPHQL_PLAYGROUND=false

# Enable API documentation (Swagger/OpenAPI)
ENABLE_API_DOCS=true

# API documentation path
API_DOCS_PATH=/api-docs

# Enable debug mode (verbose logging)
DEBUG_MODE=true

# ----------------------------------------------------------------
# PRODUCTION DEPLOYMENT SETTINGS
# ----------------------------------------------------------------
# Use these in production environments

# Production domain
PRODUCTION_DOMAIN=https://api.brookfieldproperties.com

# Production frontend domain
FRONTEND_URL=https://brookfieldproperties.com

# SSL/TLS Configuration
SSL_ENABLED=true
SSL_CERT_PATH=/path/to/ssl/cert.pem
SSL_KEY_PATH=/path/to/ssl/key.pem

# Force HTTPS redirect
FORCE_HTTPS=true

# Trusted proxy (for when behind reverse proxy like Nginx)
TRUST_PROXY=true

# ================================================================
# END OF CONFIGURATION
# ================================================================
